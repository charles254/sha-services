# SHA Cyber Services — Environment Variables
# Copy this to .env and fill in your actual values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/sha_db"

# ── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_PASSWORD="change-this-to-a-strong-password"
ADMIN_TOKEN_SECRET="must-be-at-least-32-characters-long-random-string"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://shacyberservices.com"

# ── AWS S3 (document uploads) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"
AWS_BUCKET_NAME="sha-documents"

# ── M-Pesa Daraja API ───────────────────────────────────────────────────────
MPESA_ENV="production"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://shacyberservices.com/api/mpesa/callback"

# ── Africa's Talking (SMS) ──────────────────────────────────────────────────
AT_USERNAME=""
AT_API_KEY=""
AT_SENDER_ID=""

# ── SMTP (Email) ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
